# local.env — hurl variables for the bundled docker-compose stack.
#
# Works out of the box when the stack is started with:
#   cd ../docker && docker compose --env-file dev.env up -d
#
# Usage:
#   hurl --variables-file environments/local.env --test dcs-template-demo/dcs-template-demo.hurl
#
# Each .hurl scenario opens with an inline Keycloak password-grant step
# that captures {{token}} from the response; subsequent requests use it as
# the bearer. No shell wrapper required.
#
# Prerequisite: `127.0.0.1 key-server` in /etc/hosts (per docker/README.md
# §Keycloak setup) so the token's `iss` claim matches fc-server's expected
# issuer. Without it, fc-server rejects the token even though Keycloak issued
# it successfully.
#
# The username/password and clientSecret below match the dev realm bundled
# at keycloak/realms/dev/fc-realm.json and docker/dev.env — both tracked
# files. They are dev-only fixtures, not production credentials. For hosted
# environments copy qa.env.example to qa.env (gitignored) and fill in real
# values there.

baseUrl=http://localhost:8081

keycloakUrl=http://key-server:8080
realm=federated-catalogue-realm
clientId=federated-catalogue
clientSecret=**********
username=fc-ca-test
password=CHANGE_ME_dev_only1
