# local.env — default environment for the bundled docker-compose stack.
#
# Works out of the box when the stack is started with:
#   cd ../docker && docker compose --env-file dev.env up -d
#
# Usage with hurl:
#   hurl --variables-file environments/local.env \
#        --variable token=$(./auth.sh --env environments/local.env) \
#        dcs-template-demo/dcs-template-demo.hurl
#
# Usage with auth.sh alone:
#   ./auth.sh --env environments/local.env
#
# Convention: only list variables that DIFFER from auth.sh's built-in defaults
# (admin/admin on http://localhost:8080, realm gaia-x, client federated-catalogue,
# FC_CLIENT_SECRET sourced from ../docker/dev.env). Hurl has no built-in default
# for baseUrl, so it lives here. See qa.env.example for the full list when you
# need to override anything else.

# --- hurl variables ---
baseUrl=http://localhost:8081
