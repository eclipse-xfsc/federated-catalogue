# qa.env.example — template for a hosted QA / staging instance.
#
# Copy this file to qa.env and fill in your tenant's values.
# qa.env is gitignored; this template is tracked.
#
# Usage:
#   hurl --variables-file environments/qa.env --test dcs-template-demo/dcs-template-demo.hurl

baseUrl=https://catalogue.qa.example.org

keycloakUrl=https://keycloak.qa.example.org
realm=federated-catalogue-realm
clientId=federated-catalogue
clientSecret=your-client-secret
username=your-username
password=your-password
