# qa.env.example — template for a hosted QA / staging instance.
#
# Copy this file to qa.env and fill in your tenant's values.
# qa.env is gitignored; this template is tracked.
#
# Usage with hurl:
#   hurl --variables-file environments/qa.env \
#        --variable token=$(./auth.sh --env environments/qa.env) \
#        dcs-template-demo/dcs-template-demo.hurl
#
# Usage with auth.sh alone:
#   ./auth.sh --env environments/qa.env

# --- hurl variables ---
baseUrl=https://catalogue.qa.example.org

# --- auth.sh variables ---
FC_USERNAME=your-username
FC_PASSWORD=your-password
FC_CLIENT_ID=federated-catalogue
FC_CLIENT_SECRET=your-client-secret
KEYCLOAK_URL=https://keycloak.qa.example.org
KEYCLOAK_REALM=gaia-x
